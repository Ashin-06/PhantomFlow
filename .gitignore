htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.benchmarks/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and micro-managing python versions.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may choose to ignore it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   installed in poetry. It is recommended to commit this in applications, but not libraries.
# poetry.lock

# pdm
#   Similar to Poetry and Pipenv, pdm.lock contains physical dependency resolution.
# pdm.lock

# virtualenv
venv/
ENV/
env/
active_env/
conda-env/

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Environment / Secret variables
.env
.env.*
!*.example

# Project specific databases, models and tracking files
mlflow.db
mlruns/
*.log
scratch/
certs/*.pem
certs/*.key
certs/*.crt
certs/*.pub
