# .env.example
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ─── Database ──────────────────────────────────────────────────────────────────
PG_USER=phantom
PG_PASSWORD=change_this_in_production
PG_DB=phantomflow
PG_HOST=localhost
PG_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_in_production
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
# For dev: use HS256 with a simple secret
JWT_SECRET=dev_secret_do_not_use_in_production
JWT_ALGORITHM=HS256

# For production: switch to RS256
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# ─── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=network-flows

# ─── Secrets Provider ─────────────────────────────────────────────────────────
# Options: "env" (dev), "aws" (production), "vault" (production)
SECRETS_PROVIDER=env
# AWS_REGION=us-east-1
# VAULT_URL=https://vault.corp.local

# ─── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Threat Intel APIs (optional) ─────────────────────────────────────────────
# ABUSEIPDB_API_KEY=your_key_here
# VIRUSTOTAL_API_KEY=your_key_here

# ─── ML ────────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MODEL_DIR=models/
TRAINING_MAX_ROWS=100000
